# Dependencies — reinstalled during build
node_modules

# Next.js build output — rebuilt during build
.next
out

# Local env files — injected at runtime via Dokploy
.env.local
.env.*.local

# Git
.git
.gitignore

# Editor / OS
.DS_Store
*.pem
.vscode
.idea

# Logs
npm-debug.log*
yarn-debug.log*

# Docker files themselves (no need to COPY)
Dockerfile
docker-compose.yml
.dockerignore
